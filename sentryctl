# === Selfguard command ===
cmd_selfguard() {
    local subcmd="${1:-status}"

    if [[ ! -x "$SCRIPT_DIR/sentry-selfguard.sh" ]]; then
        _error "sentry-selfguard.sh not found or not executable"
        return 1
    fi

    case "$subcmd" in
        status)
            "$SCRIPT_DIR/sentry-selfguard.sh" status
            ;;
        baseline|hash)
            "$SCRIPT_DIR/sentry-selfguard.sh" baseline
            ;;
        verify|check)
            "$SCRIPT_DIR/sentry-selfguard.sh" verify
            ;;
        start|monitor)
            echo -e "${BOLD}Starting selfguard monitor...${NC} ${DIM}(Ctrl-C to stop)${NC}"
            "$SCRIPT_DIR/sentry-selfguard.sh" start
            ;;
        *)
            _header "Selfguard — Self-Protection" "$BLUE"
            echo -e "${BOLD}Usage:${NC} sentryctl selfguard ${DIM}<subcommand>${NC}"
            echo ""
            echo -e "  ${CYAN}status${NC}     Show selfguard health and recent events"
            echo -e "  ${CYAN}baseline${NC}   Compute SHA-256 checksums of protected files"
            echo -e "  ${CYAN}verify${NC}     One-shot integrity check against baseline"
            echo -e "  ${CYAN}start${NC}      Launch fswatch self-protection monitor"
            ;;
    esac
}

