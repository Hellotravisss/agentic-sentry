#!/bin/bash
# sentryctl - Unified command line interface for Agentic Sandbox Sentry (Route C)
# This is the main user-facing tool.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Load configuration helpers
if [[ -f "$SCRIPT_DIR/sentry-config.sh" ]]; then
    source "$SCRIPT_DIR/sentry-config.sh"
    load_sentry_config 2>/dev/null || true
else
    echo -e "\033[1;33mwarning:\033[0m sentry-config.sh not found. Some features may be limited." >&2
fi

# Colors for better UX
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m' # No Color

SENTRY_VERSION="0.1.6"

# --- Visual helpers for consistent formatting ---

# Print a section header with consistent styling
# Usage: _header "Title" [color]
_header() {
    local title="$1"
    local color="${2:-$BLUE}"
    echo -e "${color}${BOLD}━━━ ${title} ━━━${NC}"
}

# Print a thin divider line
_divider() {
    echo -e "${DIM}────────────────────────────────────────${NC}"
}

# Print a colored status badge
# Usage: _badge "TEXT" color
# Colors: ok, warn, fail, info
_badge() {
    local text="$1"
    local type="${2:-info}"
    case "$type" in
        ok|green)   echo -e "${GREEN}${BOLD}✓ ${text}${NC}" ;;
        warn|yellow) echo -e "${YELLOW}${BOLD}⚠ ${text}${NC}" ;;
        fail|red)   echo -e "${RED}${BOLD}✗ ${text}${NC}" ;;
        info|blue)  echo -e "${BLUE}${BOLD}● ${text}${NC}" ;;
        *)          echo -e "${BOLD}${text}${NC}" ;;
    esac
}

# Print dimmed/hint text
_hint() {
    echo -e "  ${DIM}$*${NC}"
}

# Colorized error message
_error() {
    echo -e "${RED}error:${NC} $*" >&2
}

# Colorized success message
_success() {
    echo -e "${GREEN}✓${NC} $*"
}

cmd_dashboard() {
    load_sentry_config 2>/dev/null || true
    local current_mode="${SENTRY_MODE:-soft-block}"

    _header "Agentic Sandbox Sentry" "$BLUE"
    echo -e "  ${BOLD}Mode:${NC}    ${YELLOW}${current_mode}${NC}"

    # Component status line
    local fswatch_status selfguard_status
    if pgrep -f "sandbox-monitor.fswatch.sh" >/dev/null 2>&1; then
        fswatch_status="${GREEN}●${NC}"
    else
        fswatch_status="${YELLOW}○${NC}"
    fi
    local sg_pf="$SENTRY_LOG_DIR/selfguard.pid"
    if [[ -f "$sg_pf" ]]; then
        local sp; sp=$(cat "$sg_pf" 2>/dev/null || echo "")
        if [[ -n "$sp" ]] && kill -0 "$sp" 2>/dev/null; then
            selfguard_status="${GREEN}●${NC}"
        else
            selfguard_status="${YELLOW}○${NC}"
        fi
    else
        selfguard_status="${YELLOW}○${NC}"
    fi
    echo -e "  ${BOLD}Agents:${NC}  fswatch ${fswatch_status}  selfguard ${selfguard_status}"
    echo ""

    local log_file="${AUDIT_LOG:-${SENTRY_HOME:-$HOME/.agentsentry}/logs/sandbox-audit.log}"
    [[ ! -f "$log_file" && -f "/tmp/sandbox-audit.log" ]] && log_file="/tmp/sandbox-audit.log"

    if [[ -f "$log_file" && -s "$log_file" ]]; then
        local total blocked
        total=$(wc -l < "$log_file" | tr -d ' ')
        blocked=$(grep -cE 'SOFT_BLOCKED|HARD_ENFORCEMENT' "$log_file" 2>/dev/null) || blocked=0

        echo -e "  ${BOLD}Events:${NC}  $total total  ${RED}${blocked} blocked${NC}"
        echo ""

        _header "Recent Activity" "$CYAN"
        tail -5 "$log_file" | while read -r line; do
            if command -v jq >/dev/null 2>&1; then
                local ts decision reason
                ts=$(echo "$line" | jq -r '.ts // ""' | cut -d'T' -f2 | cut -d'+' -f1)
                decision=$(echo "$line" | jq -r '.decision // ""')
                reason=$(echo "$line" | jq -r '.reason // ""' | cut -c1-65)

                local color="$GREEN"
                [[ "$decision" == *"BLOCK"* || "$decision" == *"HARD"* ]] && color="$RED"
                [[ "$decision" == "DETECTED" ]] && color="$YELLOW"

                printf "  ${color}[%s] %s — %s${NC}\n" "$ts" "$decision" "$reason"
            else
                echo "  $line"
            fi
        done
    else
        _hint "No events recorded yet."
    fi

    echo ""
    _divider
    echo -e "  ${DIM}Commands:${NC} last ${DIM}|${NC} stats ${DIM}|${NC} watch ${DIM}|${NC} logs --follow ${DIM}|${NC} mode ${DIM}|${NC} health"
}

usage() {
    echo -e "${BOLD}Agentic Sandbox Sentry${NC} v${SENTRY_VERSION}"
    echo -e "${DIM}Runtime safety guard for local AI coding agents${NC}"
    echo ""
    echo -e "${BOLD}Usage:${NC} sentryctl ${DIM}<command>${NC} ${DIM}[options]${NC}"
    echo ""

    echo -e "${BOLD}Monitoring:${NC}"
    echo -e "  ${CYAN}dashboard${NC}        Live overview: mode, event counts, recent activity"
    echo -e "  ${CYAN}status${NC}           Full system status (hooks, fswatch, selfguard, logs)"
    echo -e "  ${CYAN}health${NC}           Component health check (exit code = health score)"
    echo -e "  ${CYAN}watch${NC}            Real-time event stream (great for monitoring AI)"
    echo -e "  ${CYAN}tui${NC}              Full-screen interactive TUI (status + violations live)"
    echo -e "  ${CYAN}selfguard${NC}        Self-protection status and integrity verification"
    echo ""

    echo -e "${BOLD}Audit & Logs:${NC}"
    echo -e "  ${CYAN}logs${NC} [search]    Powerful log viewer with filtering"
    echo -e "                   ${DIM}--tail N  --follow  --json  --blocked  --since 1h${NC}"
    echo -e "  ${CYAN}last${NC}             Show 8 most recent events (quick glance)"
    echo -e "  ${CYAN}stats${NC}            Activity statistics and top violation reasons"
    echo -e "  ${CYAN}violations${NC}       Detailed violation report (reasons, commands, severity)"
    echo -e "  ${CYAN}explain${NC} ${DIM}[N]${NC}      Full details of the Nth most recent event"
    echo -e "  ${CYAN}export${NC}           Export audit logs to JSON or CSV"
    echo ""

    echo -e "${BOLD}Configuration:${NC}"
    echo -e "  ${CYAN}mode${NC} ${DIM}[name]${NC}      Show or switch protection mode"
    echo -e "                   ${DIM}audit | warn | dry-run | soft-block | hard${NC}"
    echo -e "  ${CYAN}config${NC}           Show full effective configuration"
    echo -e "  ${CYAN}allow-dir${NC} ${DIM}<path>${NC}  Add a directory to allowed project dirs"
    echo -e "  ${CYAN}notifications${NC}    ${DIM}[on|off]${NC}  Enable/disable macOS notifications"
    echo ""

    echo -e "${BOLD}Recovery:${NC}"
    echo -e "  ${CYAN}restore${NC}          Restore network + resume frozen processes ${DIM}(needs restore code)${NC}"
    echo -e "  ${CYAN}unfreeze${NC} ${DIM}[--yes]${NC}  Resume frozen processes only ${DIM}(network untouched, no code needed)${NC}"
    echo ""

    echo -e "${BOLD}Utilities:${NC}"
    echo -e "  ${CYAN}test${NC} ${DIM}<command>${NC}    Quick heuristic test of a command"
    echo -e "  ${CYAN}check${NC} ${DIM}[--json] -- <cmd>${NC}  Full-engine verdict for agent integrations ${DIM}(exit 1 = dangerous)${NC}"
    echo -e "  ${CYAN}demo${NC}             Safe walkthrough of detection modes and example decisions"
    echo -e "  ${CYAN}rotate${NC}           Manually rotate all Sentry log files"
    echo -e "  ${CYAN}migrate-home${NC}     Move Sentry data from legacy ~/.hermes to ~/.agentsentry"
    echo ""

    _divider
    echo -e "${BOLD}Quick Start:${NC}"
    echo -e "  ${DIM}sentryctl${NC}                    ${DIM}# Dashboard — no args = useful!${NC}"
    echo -e "  ${DIM}sentryctl last${NC}               ${DIM}# Last 8 events at a glance${NC}"
    echo -e "  ${DIM}sentryctl stats${NC}              ${DIM}# Activity summary${NC}"
    echo -e "  ${DIM}sentryctl demo${NC}               ${DIM}# Safe walkthrough of risky command handling${NC}"
    echo -e "  ${DIM}sentryctl watch${NC}              ${DIM}# Live event stream${NC}"
    echo -e "  ${DIM}sentryctl logs rm -rf --since 1h${NC}  ${DIM}# Search logs${NC}"
    echo -e "  ${DIM}sentryctl mode warn${NC}          ${DIM}# Switch to warn mode${NC}"
    echo -e "  ${DIM}sentryctl health${NC}             ${DIM}# System health check${NC}"
}

cmd_status() {
    _header "Agentic Sandbox Sentry Status" "$BLUE"
    echo -e "  ${DIM}Date: $(date)${NC}"
    echo ""

    # Config
    if command -v print_sentry_config >/dev/null 2>&1; then
        print_sentry_config
    else
        echo -e "  Mode: ${YELLOW}${SENTRY_MODE:-unknown}${NC}"
    fi

    echo ""
    _header "Shell Hooks" "$CYAN"
    if [[ -n "${ZSH_VERSION:-}" ]]; then
        _badge "Running in zsh" "ok"
    else
        _badge "Not loaded in current shell" "warn"
        _hint "Run 'source sandbox-hooks.zsh' to activate"
    fi

    echo ""
    _header "Background Monitor (fswatch)" "$CYAN"
    if pgrep -f "sandbox-monitor.fswatch.sh" >/dev/null 2>&1; then
        _badge "Running" "ok"
    else
        _badge "Not running" "warn"
        _hint "Recommended: launchctl or nohup"
    fi

    echo ""
    _header "Recent Activity (last 5)" "$CYAN"
    if [[ -f "${AUDIT_LOG:-/tmp/sandbox-audit.log}" ]]; then
        tail -5 "${AUDIT_LOG:-/tmp/sandbox-audit.log}" | while read -r line; do
            if command -v jq >/dev/null 2>&1; then
                local decision reason ts
                decision=$(echo "$line" | jq -r '.decision // ""')
                reason=$(echo "$line" | jq -r '.reason // ""' | cut -c1-70)
                ts=$(echo "$line" | jq -r '.ts // ""' | cut -d'T' -f2 | cut -d'+' -f1)

                local color="$GREEN"
                [[ "$decision" == *"BLOCK"* || "$decision" == "HARD_ENFORCEMENT" ]] && color="$RED"
                [[ "$decision" == "DETECTED" ]] && color="$YELLOW"

                printf "  ${color}[%s] %s — %s${NC}\n" "$ts" "$decision" "$reason"
            else
                echo "  $line"
            fi
        done
    else
        _hint "No audit log yet"
    fi

    echo ""
    _divider
    _hint "Full history: sentryctl logs  |  Live view: sentryctl logs --follow"
}

cmd_mode() {
    local new_mode="${1:-}"

    if [[ -z "$new_mode" ]]; then
        load_sentry_config
        _header "Protection Mode" "$BLUE"
        echo -e "  Current: ${YELLOW}${BOLD}${SENTRY_MODE}${NC}"
        echo ""
        echo -e "  ${BOLD}Available modes:${NC}"
        echo -e "    ${CYAN}audit${NC}        Only log and notify ${DIM}(maximum compatibility)${NC}"
        echo -e "    ${CYAN}warn${NC}         Log + big warning, command still runs"
        echo -e "    ${CYAN}dry-run${NC}      Block + print what enforcement WOULD do ${DIM}(great for testing)${NC}"
        echo -e "    ${CYAN}soft-block${NC}   Try to block dangerous commands ${DIM}(recommended)${NC}"
        echo -e "    ${CYAN}hard${NC}         Full physical enforcement ${RED}(use with caution)${NC}"
        echo ""
        _hint "Switch: sentryctl mode <name>"
        return 0
    fi

    if set_sentry_mode "$new_mode"; then
        echo ""
        _success "Mode changed to '${YELLOW}${new_mode}${NC}'"
        _hint "You may need to reload your shell (source ~/.zshrc) for hooks to pick up the change."
    fi
}

cmd_logs() {
    local tail_count=30
    local follow=false
    local json_output=false
    local decision_filter=""
    local mode_filter=""
    local search_term=""
    local since=""

    # Parse options
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --tail|-n)
                tail_count="$2"; shift 2 ;;
            --follow|-f)
                follow=true; shift ;;
            --json)
                json_output=true; shift ;;
            --decision)
                decision_filter="$2"; shift 2 ;;
            --mode)
                mode_filter="$2"; shift 2 ;;
            --since)
                since="$2"; shift 2 ;;
            --search|--grep)
                search_term="$2"; shift 2 ;;
            --blocked|--dangerous)
                decision_filter="BLOCKED|SOFT_BLOCKED|HARD"; shift ;;
            *)
                # Treat unknown as search term
                if [[ -z "$search_term" ]]; then
                    search_term="$1"
                fi
                shift ;;
        esac
    done

    # Strong preference for the new persistent location (Route C)
    local log_file="${AUDIT_LOG:-${SENTRY_HOME:-$HOME/.agentsentry}/logs/sandbox-audit.log}"
    if [[ ! -f "$log_file" && -f "/tmp/sandbox-audit.log" ]]; then
        log_file="/tmp/sandbox-audit.log"
    fi

    if [[ ! -f "$log_file" ]]; then
        _hint "No audit log found yet."
        _hint "Logs will appear at: ${AUDIT_LOG:-$SENTRY_HOME/logs/sandbox-audit.log}"
        return 0
    fi

    # Build filter pipeline
    local filter_cmd="cat"
    if [[ -n "$search_term" ]]; then
        filter_cmd="grep -i \"$search_term\""
    fi
    if [[ -n "$decision_filter" ]]; then
        filter_cmd="$filter_cmd | grep -E '\"decision\"[^,]*($decision_filter)'"
    fi
    if [[ -n "$mode_filter" ]]; then
        filter_cmd="$filter_cmd | grep -i '\"mode\"[^,]*$mode_filter'"
    fi

    local tail_cmd="tail -n $tail_count"
    if $follow; then
        tail_cmd="tail -n 0 -f"
    fi

    # Time filter (simple implementation)
    if [[ -n "$since" ]]; then
        local since_epoch
        case "$since" in
            *h|*H) since_epoch=$(date -v -${since%?}H +%s 2>/dev/null || date -d "$since ago" +%s 2>/dev/null || echo 0) ;;
            *m|*M) since_epoch=$(date -v -${since%?}M +%s 2>/dev/null || date -d "$since ago" +%s 2>/dev/null || echo 0) ;;
            today|Today) since_epoch=$(date -v 0H +%s 2>/dev/null || date -d 'today 00:00' +%s 2>/dev/null || echo 0) ;;
            *) since_epoch=0 ;;
        esac
        if [[ "$since_epoch" != "0" ]]; then
            filter_cmd="$filter_cmd | while read -r l; do ts=\$(echo \"\$l\" | grep -oE '[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9:]+'); ts_epoch=\$(date -j -f '%Y-%m-%dT%H:%M:%S' \"\${ts%:*}\" +%s 2>/dev/null || echo 0); [[ \$ts_epoch -ge $since_epoch ]] && echo \"\$l\"; done"
        fi
    fi

    if $json_output; then
        eval "$tail_cmd \"$log_file\" | $filter_cmd"
        return
    fi

    echo -e "${BLUE}${BOLD}━━━ Sentry Logs ━━━${NC}"
    echo -e "  ${DIM}file: $log_file${NC}"
    if [[ -n "$search_term$decision_filter$mode_filter$since" ]]; then
        echo -e "  ${DIM}filters:${NC} search='${search_term}' decision='${decision_filter}' mode='${mode_filter}' since='${since}'"
    fi
    echo ""

    # Main pipeline
    eval "$tail_cmd \"$log_file\" | $filter_cmd" | while read -r line; do
        if command -v jq >/dev/null 2>&1; then
            local ts mode decision reason cmd_str cwd
            ts=$(echo "$line" | jq -r '.ts // ""' 2>/dev/null | cut -d'T' -f2 | cut -d'+' -f1)
            mode=$(echo "$line" | jq -r '.mode // "unknown"')
            decision=$(echo "$line" | jq -r '.decision // ""')
            reason=$(echo "$line" | jq -r '.reason // ""')
            cmd_str=$(echo "$line" | jq -r '.cmd // ""' | cut -c1-90)
            cwd=$(echo "$line" | jq -r '.cwd // ""' | sed "s|$HOME|~|g" | cut -c1-60)

            local color="$NC" icon="•"
            case "$decision" in
                *BLOCKED*|HARD_ENFORCEMENT) color="$RED"; icon="🛑" ;;
                SOFT_BLOCKED) color="$RED"; icon="⛔" ;;
                DETECTED) color="$YELLOW"; icon="⚠️ " ;;
                *) color="$GREEN"; icon="ℹ️ " ;;
            esac

            printf "${color}%s [%s] %s %s${NC}\n" "$ts" "$mode" "$icon" "$decision"
            printf "   %s\n" "$reason"
            printf "   cmd: %s\n" "$cmd_str"
            [[ -n "$cwd" ]] && printf "   cwd: %s\n" "$cwd"
            echo ""
        else
            echo "$line"
        fi
    done
}

cmd_config() {
    _header "Sentry Configuration" "$BLUE"
    if command -v print_sentry_config >/dev/null 2>&1; then
        print_sentry_config
    else
        _hint "Config loader not available"
    fi

    echo ""
    echo -e "  ${BOLD}Config file:${NC} ${DIM}${SENTRY_CONFIG:-$SENTRY_HOME/sentry-config.json}${NC}"
}

cmd_allow_dir() {
    local new_dir="$1"

    if [[ -z "$new_dir" ]]; then
        echo -e "${BOLD}Usage:${NC} sentryctl allow-dir ${DIM}<absolute-or-relative-path>${NC}"
        return 1
    fi

    # Expand to absolute path
    new_dir=$(cd "$new_dir" 2>/dev/null && pwd || echo "$new_dir")

    local rules_file="${SAFETY_RULES:-$SENTRY_HOME/safety-rules.json}"

    if [[ ! -f "$rules_file" ]]; then
        _error "Safety rules file not found: $rules_file"
        return 1
    fi

    if ! command -v jq >/dev/null 2>&1; then
        _error "jq is required to modify rules. Install with: brew install jq"
        return 1
    fi

    # Add the directory if not already present
    local tmp
    tmp=$(mktemp)

    if jq --arg dir "$new_dir" '
        .allowed_project_dirs = (
            (.allowed_project_dirs // []) + [$dir] | unique
        )
    ' "$rules_file" > "$tmp"; then
        mv "$tmp" "$rules_file"
        _success "Added to allowed directories: ${CYAN}$new_dir${NC}"
        _hint "You may need to reload your shell for the change to take effect."
    else
        rm -f "$tmp"
        _error "Failed to update rules file."
        return 1
    fi
}

cmd_last() {
    # Convenience alias for recent interesting events
    cmd_logs --tail 8 "$@"
}

# Move Sentry-owned files out of the legacy ~/.hermes home (which collides
# with Hermes Agent's config directory) into ~/.agentsentry. Only touches
# files Sentry created; everything else in ~/.hermes is left alone.
cmd_migrate_home() {
    local legacy="$HOME/.hermes"
    local new_home="$HOME/.agentsentry"

    if [[ -n "${SENTRY_HOME:-}" && "$SENTRY_HOME" != "$legacy" && "$SENTRY_HOME" != "$new_home" ]]; then
        _error "SENTRY_HOME is set to a custom path ($SENTRY_HOME) — nothing to migrate."
        return 1
    fi
    if [[ ! -f "$legacy/sentry-config.json" ]]; then
        _success "No legacy Sentry data in $legacy — already migrated or fresh install."
        return 0
    fi
    if [[ -f "$new_home/sentry-config.json" ]]; then
        _error "$new_home already has a config. Resolve manually to avoid overwriting."
        return 1
    fi

    _header "Migrating Sentry home: $legacy → $new_home" "$BLUE"
    mkdir -p "$new_home/logs"
    chmod 700 "$new_home" 2>/dev/null || true

    local moved=0 f
    for f in sentry-config.json safety-rules.json agentsentry-restore.code; do
        if [[ -f "$legacy/$f" ]]; then
            mv "$legacy/$f" "$new_home/$f"
            echo "  moved $f"
            ((moved++)) || true
        fi
    done
    for f in "$legacy"/logs/sandbox-audit.log* "$legacy"/logs/enforcement.log* \
             "$legacy"/logs/selfguard.log* "$legacy"/logs/.rotate_counter \
             "$legacy"/logs/selfguard.pid; do
        if [[ -e "$f" ]]; then
            mv "$f" "$new_home/logs/$(basename "$f")"
            echo "  moved logs/$(basename "$f")"
            ((moved++)) || true
        fi
    done

    # Rewrite the absolute audit_log path stored inside the config
    if command -v jq >/dev/null 2>&1; then
        local tmp
        tmp=$(mktemp)
        jq --arg p "$new_home/logs/sandbox-audit.log" '.audit_log = $p' \
            "$new_home/sentry-config.json" > "$tmp" && mv "$tmp" "$new_home/sentry-config.json"
        echo "  updated audit_log path in config"
    fi

    echo ""
    _success "Migrated $moved item(s). Sentry now lives in $new_home."
    _hint "Other files in $legacy (Hermes Agent's own data) were not touched."
    _hint "Reload your shell (source ~/.zshrc) so hooks pick up the new path."
}

# Machine-readable verdict for agent integrations (Claude Code, Codex,
# OpenClaw, custom platforms). Exit 0 = safe, 1 = dangerous, 2 = error.
cmd_check() {
    local json=false do_log=false component="check" cwd="$PWD"
    local -a words=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json) json=true; shift ;;
            --log) do_log=true; shift ;;
            --component) component="$2"; shift 2 ;;
            --cwd) cwd="$2"; shift 2 ;;
            --) shift; words+=("$@"); break ;;
            *) words+=("$1"); shift ;;
        esac
    done

    local check_cmd="${words[*]:-}"
    if [[ -z "$check_cmd" ]]; then
        echo "Usage: sentryctl check [--json] [--log] [--component NAME] [--cwd DIR] -- <command string>" >&2
        return 2
    fi

    if [[ ! -f "$SCRIPT_DIR/sentry-check.sh" ]]; then
        echo "Error: sentry-check.sh not found" >&2
        return 2
    fi
    # shellcheck source=/dev/null
    source "$SCRIPT_DIR/sentry-check.sh"

    local verdict="safe" reason="" rc=0
    if sentry_check_command "$check_cmd" "$cwd"; then
        verdict="dangerous"
        reason="$SENTRY_CHECK_REASON"
        rc=1
    elif [[ $? -eq 2 ]]; then
        echo "Error: cannot evaluate (zsh not available)" >&2
        return 2
    fi

    local mode
    mode=$(get_sentry_mode 2>/dev/null || echo "unknown")

    if [[ "$do_log" == true && "$verdict" == "dangerous" && -f "$SCRIPT_DIR/sentry-logger.sh" ]] \
        && ! command -v sentry_log >/dev/null 2>&1; then
        # shellcheck source=/dev/null
        source "$SCRIPT_DIR/sentry-logger.sh" >/dev/null 2>&1 || true
    fi
    if [[ "$do_log" == true && "$verdict" == "dangerous" ]] && command -v sentry_log >/dev/null 2>&1; then
        local safe_cmd
        safe_cmd=$(printf '%s' "$check_cmd" | head -c 300 | sed 's/\\/\\\\/g; s/"/\\"/g' | tr -d '\n\t')
        sentry_log "CHECK_DANGEROUS" "$reason" "$component" "{\"cmd\":\"$safe_cmd\",\"cwd\":\"$cwd\",\"mode\":\"$mode\"}" 2>/dev/null || true
    fi

    if [[ "$json" == true ]]; then
        if command -v jq >/dev/null 2>&1; then
            jq -cn --arg v "$verdict" --arg r "$reason" --arg m "$mode" \
                '{verdict: $v, reason: $r, mode: $m}'
        else
            printf '{"verdict":"%s","reason":"%s","mode":"%s"}\n' "$verdict" "$reason" "$mode"
        fi
    else
        if [[ "$verdict" == "dangerous" ]]; then
            echo "DANGEROUS: $reason (mode: $mode)"
        else
            echo "SAFE (mode: $mode)"
        fi
    fi

    return $rc
}

cmd_test() {
    local test_cmd="$*"

    if [[ -z "$test_cmd" ]]; then
        echo -e "${BOLD}Usage:${NC} sentryctl test ${DIM}<command string>${NC}"
        echo -e "${DIM}Example: sentryctl test 'rm -rf /tmp/important'${NC}"
        return 1
    fi

    _header "Command Test" "$BLUE"
    echo -e "  ${BOLD}Testing:${NC} ${YELLOW}$test_cmd${NC}"
    echo ""

    # Delegate to the real engine (same verdict the hooks and agent
    # integrations get) instead of a separate heuristic.
    local verdict_json
    if verdict_json=$(cmd_check --json -- "$test_cmd" 2>/dev/null); then
        _badge "SAFE — would be allowed" "ok"
    else
        local reason=""
        if command -v jq >/dev/null 2>&1; then
            reason=$(echo "$verdict_json" | jq -r '.reason // ""' 2>/dev/null || echo "")
        fi
        _badge "DANGEROUS — would be flagged" "fail"
        [[ -n "$reason" ]] && echo -e "  ${DIM}Reason: ${reason}${NC}"
    fi

    echo ""
    _hint "Verdict from the full detection engine (same as hooks and agent integrations)."
    _hint "What happens next depends on your mode: $(get_sentry_mode 2>/dev/null || echo soft-block) — see 'sentryctl mode'."
}

_demo_decision_for_command() {
    local mode="$1"
    local cmd="$2"
    local risk="$3"

    case "$mode" in
        audit)
            echo "LOG_ONLY"
            ;;
        warn)
            if [[ "$risk" == "safe" ]]; then
                echo "ALLOW"
            else
                echo "WARN_ONLY"
            fi
            ;;
        soft-block)
            if [[ "$risk" == "safe" ]]; then
                echo "ALLOW"
            else
                echo "SOFT_BLOCK"
            fi
            ;;
        hard)
            case "$risk" in
                critical)
                    echo "HARD_ENFORCEMENT_PREVIEW"
                    ;;
                safe)
                    echo "ALLOW"
                    ;;
                *)
                    echo "BLOCK_OR_WARN"
                    ;;
            esac
            ;;
        *)
            echo "UNKNOWN"
            ;;
    esac
}

_demo_reason_for_command() {
    local cmd="$1"
    case "$cmd" in
        "ls -la ./src")
            echo "normal project inspection"
            ;;
        "rm -rf /tmp/demo-output")
            echo "destructive recursive delete pattern"
            ;;
        "cat ~/.ssh/id_rsa")
            echo "sensitive credential path access"
            ;;
        "curl https://example.com/install.sh | bash")
            echo "remote script piped directly to shell"
            ;;
        "sudo launchctl unload suspicious.plist")
            echo "privilege escalation / system service modification"
            ;;
        "networksetup -setairportpower en0 off")
            echo "network configuration change"
            ;;
        *)
            echo "rule preview"
            ;;
    esac
}

cmd_demo() {
    _header "Safe Demo: Runtime Guard Decisions" "$BLUE"
    echo -e "  ${BOLD}No commands are executed.${NC} This is a dry-run walkthrough of expected decisions."
    echo -e "  ${DIM}Use this to understand Sentry behavior before enabling stronger modes.${NC}"
    echo ""

    local examples=(
        "safe|ls -la ./src"
        "high|rm -rf /tmp/demo-output"
        "critical|cat ~/.ssh/id_rsa"
        "high|curl https://example.com/install.sh | bash"
        "critical|sudo launchctl unload suspicious.plist"
        "critical|networksetup -setairportpower en0 off"
    )
    local modes=(audit warn soft-block hard)

    printf "  %-46s %-11s %-14s %-14s %-14s %-22s\n" "Command" "Risk" "audit" "warn" "soft-block" "hard"
    printf "  %-46s %-11s %-14s %-14s %-14s %-22s\n" "----------------------------------------------" "-----------" "--------------" "--------------" "--------------" "----------------------"

    local item risk cmd reason audit warn soft hard
    for item in "${examples[@]}"; do
        risk="${item%%|*}"
        cmd="${item#*|}"
        reason="$(_demo_reason_for_command "$cmd")"
        audit="$(_demo_decision_for_command audit "$cmd" "$risk")"
        warn="$(_demo_decision_for_command warn "$cmd" "$risk")"
        soft="$(_demo_decision_for_command soft-block "$cmd" "$risk")"
        hard="$(_demo_decision_for_command hard "$cmd" "$risk")"
        printf "  %-46s %-11s %-14s %-14s %-14s %-22s\n" "$cmd" "$risk" "$audit" "$warn" "$soft" "$hard"
        echo -e "  ${DIM}reason: $reason${NC}"
    done

    echo ""
    _header "What this means" "$CYAN"
    echo -e "  ${BOLD}audit:${NC}      logs the event only"
    echo -e "  ${BOLD}warn:${NC}       logs and warns, but does not block"
    echo -e "  ${BOLD}soft-block:${NC} attempts to block risky commands at the shell hook layer"
    echo -e "  ${BOLD}hard:${NC}       may trigger emergency network/process controls for critical events"
    echo ""
    _hint "Demo mode never cuts network access, freezes processes, or runs the sample commands."
    _hint "For one-off checks, use: sentryctl test '<command>'"
}

cmd_notifications() {
    local action="${1:-}"

    ensure_sentry_config

    case "$action" in
        on|true|enable)
            if command -v jq >/dev/null 2>&1; then
                jq '.notifications = true' "$SENTRY_CONFIG" > /tmp/sentrycfg.$$ && mv /tmp/sentrycfg.$$ "$SENTRY_CONFIG"
            fi
            _success "Notifications enabled"
            ;;
        off|false|disable)
            if command -v jq >/dev/null 2>&1; then
                jq '.notifications = false' "$SENTRY_CONFIG" > /tmp/sentrycfg.$$ && mv /tmp/sentrycfg.$$ "$SENTRY_CONFIG"
            fi
            _success "Notifications disabled"
            ;;
        *)
            load_sentry_config
            _header "Notifications" "$BLUE"
            echo -e "  Status: ${YELLOW}${SENTRY_NOTIFICATIONS}${NC}"
            echo ""
            _hint "Usage: sentryctl notifications [on|off]"
            ;;
    esac
}

# === New powerful commands for excellent audit experience ===

cmd_stats() {
    local log_file="${AUDIT_LOG:-${SENTRY_HOME:-$HOME/.agentsentry}/logs/sandbox-audit.log}"
    [[ ! -f "$log_file" && -f "/tmp/sandbox-audit.log" ]] && log_file="/tmp/sandbox-audit.log"

    if [[ ! -f "$log_file" ]]; then
        _hint "No audit log found."
        return 0
    fi

    _header "Sentry Activity Summary" "$BLUE"
    echo ""

    local total
    total=$(wc -l < "$log_file" 2>/dev/null | tr -d ' ' || echo 0)

    if ! command -v jq >/dev/null 2>&1; then
        _hint "jq recommended for rich stats (brew install jq)"
        echo -e "  Total events: $total"
        return
    fi

    local soft_blocked hard detected
    soft_blocked=$(grep -c 'SOFT_BLOCKED' "$log_file" 2>/dev/null) || soft_blocked=0
    hard=$(grep -c 'HARD_ENFORCEMENT' "$log_file" 2>/dev/null) || hard=0
    detected=$(grep -c '"decision":"DETECTED"' "$log_file" 2>/dev/null) || detected=0

    echo -e "  ${BOLD}Total events logged:${NC}     $total"
    echo ""
    echo -e "  ${RED}Soft blocks (prevented):${NC} $soft_blocked"
    echo -e "  ${RED}Hard enforcement runs:${NC}   $hard"
    echo -e "  ${YELLOW}Just detected (allowed):${NC} $detected"
    echo ""

    _header "Top Reasons" "$CYAN"
    jq -r '.reason // empty' "$log_file" 2>/dev/null |
        sort | uniq -c | sort -rn | head -6 | while read -r count reason; do
            printf "    %4s  %s\n" "$count" "$reason"
        done 2>/dev/null || _hint "(no data yet)"

    echo ""
    _header "Events by Mode" "$CYAN"
    jq -r '.mode // "unknown"' "$log_file" 2>/dev/null |
        sort | uniq -c | sort -rn | while read -r count mode; do
            printf "    %4s  %s\n" "$count" "$mode"
        done 2>/dev/null || _hint "(no data yet)"
}

cmd_explain() {
    local index="${1:-1}"   # default to the most recent
    local log_file="${AUDIT_LOG:-${SENTRY_HOME:-$HOME/.agentsentry}/logs/sandbox-audit.log}"
    [[ ! -f "$log_file" && -f "/tmp/sandbox-audit.log" ]] && log_file="/tmp/sandbox-audit.log"

    if [[ ! -f "$log_file" ]]; then
        _error "No audit log found."
        return 1
    fi

    if ! command -v jq >/dev/null 2>&1; then
        _hint "jq is strongly recommended for explain. Falling back to raw line."
        tail -n "$index" "$log_file" | tail -1
        return
    fi

    local line
    line=$(tail -n "$index" "$log_file" | tail -1)

    if [[ -z "$line" ]]; then
        _error "No event found at position $index"
        return 1
    fi

    _header "Sentry Event Detail (#$index)" "$BLUE"
    echo "$line" | jq -C .

    echo ""
    _header "Quick Actions" "$YELLOW"
    _hint "Surrounding context: sentryctl logs --tail 20"
    _hint "Live watch:         sentryctl watch"
}

cmd_watch() {
    echo -e "${BLUE}=== Sentry Live Watch (Ctrl-C to exit) ===${NC}"
    echo "Press Ctrl-C to stop."
    echo ""

    local log_file="${AUDIT_LOG:-${SENTRY_HOME:-$HOME/.agentsentry}/logs/sandbox-audit.log}"
    [[ ! -f "$log_file" && -f "/tmp/sandbox-audit.log" ]] && log_file="/tmp/sandbox-audit.log"

    if [[ ! -f "$log_file" ]]; then
        echo "Waiting for log file to appear..."
        while [[ ! -f "$log_file" ]]; do sleep 1; done
    fi

    tail -n 5 -f "$log_file" | while read -r line; do
        if command -v jq >/dev/null 2>&1; then
            local decision reason ts
            decision=$(echo "$line" | jq -r '.decision // ""')
            reason=$(echo "$line" | jq -r '.reason // ""' | cut -c1-60)
            ts=$(echo "$line" | jq -r '.ts // ""' | cut -d'T' -f2 | cut -d'+' -f1)

            local color="$GREEN"
            [[ "$decision" == *"BLOCK"* || "$decision" == *"HARD"* ]] && color="$RED"
            [[ "$decision" == "DETECTED" ]] && color="$YELLOW"

            printf "\r${color}[%s] %s - %s${NC}\033[K\n" "$ts" "$decision" "$reason"
        else
            echo "$line"
        fi
    done
}

# === New: Export for audits ===
cmd_export() {
    local format="json"
    local since=""
    local outfile=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --format) format="$2"; shift 2 ;;
            --since)  since="$2"; shift 2 ;;
            -o|--output) outfile="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    load_sentry_config 2>/dev/null || true
    local log_file="${AUDIT_LOG:-${SENTRY_HOME:-$HOME/.agentsentry}/logs/sandbox-audit.log}"
    [[ ! -f "$log_file" && -f "/tmp/sandbox-audit.log" ]] && log_file="/tmp/sandbox-audit.log"

    if [[ ! -f "$log_file" ]]; then
        _error "No log file to export."
        return 1
    fi

    local filter="cat"
    if [[ -n "$since" ]]; then
        # simple since filter (reuse some logic)
        filter="grep -E '20[0-9]{2}-[0-9]{2}-[0-9]{2}'"  # rough
    fi

    if [[ -z "$outfile" ]]; then
        outfile="sentry-export-$(date +%Y%m%d-%H%M%S).${format}"
    fi

    case "$format" in
        json)
            eval "$filter \"$log_file\"" > "$outfile"
            ;;
        csv)
            echo "timestamp,mode,decision,reason,command,cwd" > "$outfile"
            if command -v jq >/dev/null 2>&1; then
                jq -r '[.ts, .mode, .decision, .reason, .cmd, .cwd] | @csv' "$log_file" >> "$outfile" 2>/dev/null || true
            else
                echo -e "${YELLOW}CSV export works best with jq installed.${NC}"
            fi
            ;;
        *)
            _error "Supported formats: json, csv"
            return 1
            ;;
    esac

    _success "Exported to: ${CYAN}$outfile${NC}"
}

