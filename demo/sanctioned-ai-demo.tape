# vhs tape — regenerate the demo GIF with:  vhs demo/sanctioned-ai-demo.tape
# (run from the repo root). Requires: vhs (brew install vhs).
Output demo/sanctioned-ai-demo.gif

Set Shell "bash"
Set FontSize 15
Set Width 1180
Set Height 900
Set Padding 20
Set Theme "Dracula"
Set TypingSpeed 60ms

Type "./demo/sanctioned-ai-demo.sh --fast"
Sleep 600ms
Enter
Sleep 9s
Sleep 2s
